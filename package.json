{
    "name": "petal",
    "version": "1.0.0",
    "license": "MIT",
    "type": "module",
    "scripts": {
        "dev": "tauri dev",
        "vite:dev": "vite",
        "build": "vue-tsc --noEmit && vite build",
        "tauri:build": "tauri build",
        "tauri:build:mac:universal": "tauri build --target universal-apple-darwin",
        "tauri:build:mac:arm": "tauri build --target aarch64-apple-darwin",
        "tauri:build:mac:intel": "tauri build --target x86_64-apple-darwin",
        "tauri:build:linux": "tauri build",
        "tauri:build:win": "tauri build",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "type-check": "vue-tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "preview": "vite preview",
        "tauri": "tauri",
        "ci:check": "npm run lint && npm run format:check && npm run type-check && npm run build && npm run test",
        "prepare": "husky",
        "icons:generate": "node scripts/generate-icons.js"
    },
    "lint-staged": {
        "*.{ts,vue}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{scss,json,md}": [
            "prettier --write"
        ]
    },
    "dependencies": {
        "@tauri-apps/api": "^2",
        "@tauri-apps/plugin-dialog": "^2.6.0",
        "@tauri-apps/plugin-opener": "^2",
        "vue": "^3.5.13"
    },
    "devDependencies": {
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "@tauri-apps/cli": "^2",
        "@vitejs/plugin-vue": "^5.2.1",
        "@vitest/coverage-v8": "^4.1.0",
        "@vue/test-utils": "^2.4.6",
        "eslint": "^10.1.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-vue": "^10.8.0",
        "husky": "^9.1.7",
        "icon-gen": "^5.0.0",
        "jsdom": "^29.0.1",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.1",
        "sass": "^1.98.0",
        "sharp": "^0.34.5",
        "typescript": "~5.6.2",
        "typescript-eslint": "^8.57.1",
        "vite": "^6.0.3",
        "vitest": "^4.1.0",
        "vue-tsc": "^2.1.10"
    }
}
